FROM registry.access.redhat.com/ubi9/python-312

LABEL io.k8s.display-name="ADK Agent Harness" \
      io.k8s.description="Google ADK file-processing agent with Flask web UI" \
      io.openshift.expose-services="8080:http" \
      io.openshift.tags="python,adk,agent"

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY README.md .
COPY adk_agent.py .
COPY web_app.py .
COPY templates/ templates/

ENV AGENT_DIR=/app/agent \
    INPUT_DIR=/app/input \
    OUTPUT_DIR=/app/output \
    API_PROVIDER=anthropic \
    MODEL=claude-opus-4-5 \
    MAX_TURNS=50 \
    ALLOW_SHELL=true \
    SHELL_TIMEOUT=60 \
    PORT=8080 \
    HOST=0.0.0.0

USER 0
RUN mkdir -p /app/agent /app/input /app/output && \
    chown -R 1001:0 /app && \
    chmod -R g=u /app

VOLUME ["/app/agent", "/app/input", "/app/output"]

EXPOSE 8080

USER 1001

CMD ["python", "/app/web_app.py"]
